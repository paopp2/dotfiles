#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: review-doc [--source-pane <pane_id>] <file-path>"
  echo ""
  echo "Open a markdown file for review in a new tmux pane using yazi."
  echo ""
  echo "Options:"
  echo "  --source-pane <id>   Pane to split from (default: current pane)"
  echo "  -h, --help           Show this help"
  exit 0
}

SOURCE_PANE_ARG=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --source-pane) SOURCE_PANE_ARG="--source-pane $2"; shift 2 ;;
    -h|--help) usage ;;
    --) shift; break ;;
    *) break ;;
  esac
done

if [[ $# -eq 0 ]]; then
  echo "Error: No file path specified" >&2
  echo "Usage: review-doc [options] <file-path>" >&2
  exit 1
fi

FILE_PATH="$1"

if [[ ! -f "$FILE_PATH" ]]; then
  echo "Error: File not found: $FILE_PATH" >&2
  exit 1
fi

# Use absolute path
FILE_PATH=$(cd "$(dirname "$FILE_PATH")" && pwd)/$(basename "$FILE_PATH")

# Split pane with yazi, capture new pane ID
# shellcheck disable=SC2086
NEW_PANE=$(tmux-split $SOURCE_PANE_ARG --print-pane-id -- "zsh -ic \"r $FILE_PATH; exec zsh\"")

# Wait for yazi to start, then send 'o' to trigger the opener
sleep 1
tmux send-keys -t "$NEW_PANE" 'o'
